<section id="pricing" class="section-padding" style="background: #000; padding: 8rem 0; border-top: 1px solid rgba(255,255,255,0.05);">
    <div class="container">
        <h2 class="text-center animate-on-scroll" style="font-size: 3rem; margin-bottom: 4rem;">Investment Plans</h2>
        <div class="pricing-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 3rem; margin-top: 4rem;">
            <!-- Growth Partner Tier -->
            <div class="pricing-card"
                style="border: 1px solid rgba(59,130,246,0.1); padding: 4rem 3rem; border-radius: 32px; background: linear-gradient(145deg, rgba(59,130,246,0.03), transparent); position: relative; overflow: hidden; backdrop-filter: blur(10px);">
                <div
                    style="position: absolute; top: 1.5rem; right: 1.5rem; background: #3b82f6; color: #fff; padding: 4px 12px; border-radius: 20px; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.05em;">
                    MOST POPULAR</div>
                <div style="color: #3b82f6; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem;">Scale Operations</div>
                <h3 style="font-size: 1.75rem; margin-bottom: 0.5rem;">Growth Partner</h3>
                <div style="font-size: 3rem; font-weight: 800; margin: 1.5rem 0; letter-spacing: -0.02em;">$4,500<span
                        style="font-size: 1rem; color: #a1a1aa; font-weight: 400;">/mo</span></div>
                <p style="color: #a1a1aa; margin-bottom: 2.5rem; font-size: 0.95rem; line-height: 1.6;">Continuous engineering and performance optimization to scale your digital presence.</p>
                <ul style="list-style: none; padding: 0; color: #fff; line-height: 2.2; margin-bottom: 3rem;">
                    <li style="display: flex; align-items: center; gap: 0.75rem;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Weekly Performance Engineering</li>
                    <li style="display: flex; align-items: center; gap: 0.75rem;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> A/B Testing & Conversion Tuning</li>
                    <li style="display: flex; align-items: center; gap: 0.75rem;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Security & Patch Management</li>
                    <li style="display: flex; align-items: center; gap: 0.75rem;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Priority Engineering Support</li>
                </ul>
                <a href="#contact" class="btn btn-blue"
                    style="display: block; width: 100%; text-align: center; padding: 1.2rem; border-radius: 100px; text-decoration: none; font-weight: 700; letter-spacing: 0.02em;">Start Growth Partnership</a>
            </div>

            <!-- Enterprise Tier -->
            <div class="pricing-card"
                style="border: 1px solid rgba(255,255,255,0.05); padding: 4rem 3rem; border-radius: 32px; background: rgba(255,255,255,0.01); backdrop-filter: blur(10px);">
                <div style="color: #a1a1aa; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem;">Global Infrastructure</div>
                <h3 style="font-size: 1.75rem; margin-bottom: 0.5rem;">Enterprise Engineering</h3>
                <div style="font-size: 3rem; font-weight: 800; margin: 1.5rem 0; letter-spacing: -0.02em;">Custom<span
                        style="font-size: 1rem; color: #a1a1aa; font-weight: 400;">/project</span></div>
                <p style="color: #a1a1aa; margin-bottom: 2.5rem; font-size: 0.95rem; line-height: 1.6;">Dedicated engineering team for complex distributed systems and large-scale migrations.</p>
                <ul style="list-style: none; padding: 0; color: #fff; line-height: 2.2; margin-bottom: 3rem;">
                    <li style="display: flex; align-items: center; gap: 0.75rem;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#a1a1aa" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> 24/7 Mission-Critical Coverage</li>
                    <li style="display: flex; align-items: center; gap: 0.75rem;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#a1a1aa" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Multi-Region Architecture</li>
                    <li style="display: flex; align-items: center; gap: 0.75rem;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#a1a1aa" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Legacy System Modernization</li>
                    <li style="display: flex; align-items: center; gap: 0.75rem;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#a1a1aa" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> White-glove DevSecOps</li>
                </ul>
                <a href="#contact" class="btn btn-outline"
                    style="display: block; width: 100%; text-align: center; padding: 1.2rem; border-radius: 100px; text-decoration: none; font-weight: 700; border-color: rgba(255,255,255,0.1);">Contact Strategy Team</a>
            </div>
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Pricing",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection",
      "info": "If selected, products from this collection will replace the hardcoded plans above."
    }
  ]
}
{% endschema %}

