<section id="stats" class="section-padding" style="background: #000; border-top: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color);">
    <div class="container">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 3rem; text-align: center;">
            <div class="stat-item animate-on-scroll">
                <div style="font-size: 3.5rem; font-weight: 800; color: #fff; line-height: 1;">99.9%</div>
                <div style="color: #3b82f6; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-top: 0.5rem;">System Uptime</div>
            </div>
            <div class="service-header text-center animate-on-scroll">
                <h1 class="service-title" style="background: linear-gradient(to right, #fff, #3b82f6); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Search Engineering Dominance</h1>
                <p class="service-subtitle">We don't just optimize meta tags. We engineer your site to rank #1 on Google's technical stack.</p>
            </div>
            <div class="stat-item animate-on-scroll">
                <div style="font-size: 3.5rem; font-weight: 800; color: #fff; line-height: 1;">&lt; 50ms</div>
                <div style="color: #3b82f6; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-top: 0.5rem;">API Response</div>
            </div>
            <div class="stat-item animate-on-scroll">
                <div style="font-size: 3.5rem; font-weight: 800; color: #fff; line-height: 1;">100+</div>
                <div style="color: #3b82f6; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-top: 0.5rem;">KE Systems Deployed</div>
            </div>
            <div class="stat-item animate-on-scroll">
                <div style="font-size: 3.5rem; font-weight: 800; color: #fff; line-height: 1;">24/7</div>
                <div style="color: #3b82f6; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-top: 0.5rem;">Local Engineering Support</div>
            </div>
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Stats Kenya",
  "settings": []
}
{% endschema %}
