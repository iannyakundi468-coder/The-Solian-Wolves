<section id="services" class="section-padding" style="content-visibility: auto; contain-intrinsic-size: 100vh;">
    <div class="container">
        <h2 class="text-center animate-on-scroll" style="font-size: 3rem; margin-bottom: var(--spacing-lg);">Our
            Expertise</h2>
        <div class="services-grid">
            <!-- Box 1: Custom Software Engineering -->
            <a href="/pages/software-engineering" class="service-card animate-on-scroll" aria-label="Learn about Custom Software Engineering" style="border: 2px solid #3b82f6; box-shadow: 0 0 20px rgba(59, 130, 246, 0.2); text-decoration: none; display: block; color: inherit;">
                <div class="service-icon" aria-hidden="true" style="color: #3b82f6;">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 2rem; height: 2rem;"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" /></svg>
                </div>
                <h3>Custom Software Engineering</h3>
                <p style="color: var(--text-secondary); margin-top: 0.5rem; margin-bottom: 1rem;">We build robust, scalable, and secure software applications tailored to your business needs, from enterprise SaaS to high-performance mobile apps.</p>
                <span class="learn-more" style="color: #3b82f6; font-size: 0.9rem; font-weight: 600;">Learn More &rarr;</span>
            </a>

            <!-- Box 2: Systems Architecture & Cloud -->
            <a href="/pages/systems-architecture" class="service-card animate-on-scroll" aria-label="Learn about Systems Architecture" style="text-decoration: none; display: block; color: inherit;">
                <div class="service-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 2rem; height: 2rem;"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h18v18H3V3z" /></svg>
                </div>
                <h3>Cloud & Systems Architecture</h3>
                <p style="color: var(--text-secondary); margin-top: 0.5rem; margin-bottom: 1rem;">Design for scale. We architect distributed systems and cloud infrastructure that grow with your user base without breaking the bank.</p>
                <span class="learn-more" style="color: #3b82f6; font-size: 0.9rem; font-weight: 600;">Learn More &rarr;</span>
            </a>

            <!-- Box 3: Legacy System Modernization -->
            <a href="/pages/modernization" class="service-card animate-on-scroll" aria-label="Learn about System Modernization" style="text-decoration: none; display: block; color: inherit;">
                <div class="service-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 2rem; height: 2rem;"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" /></svg>
                </div>
                <h3>Legacy System Modernization</h3>
                <p style="color: var(--text-secondary); margin-top: 0.5rem; margin-bottom: 1rem;">Transform your tech debt into a competitive advantage. We refactor old codebases and migrate legacy systems to modern, maintainable stacks.</p>
                <span class="learn-more" style="color: #3b82f6; font-size: 0.9rem; font-weight: 600;">Learn More &rarr;</span>
            </a>

            <!-- Box 4: AI & Data Engineering -->
            <a href="/pages/ai-data" class="service-card animate-on-scroll" aria-label="Learn about AI & Data Engineering" style="text-decoration: none; display: block; color: inherit;">
                <div class="service-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 2rem; height: 2rem;"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v17.792m0-17.792L14.25 12l-4.5 8.896m0-17.792L5.25 12l4.5 8.896M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <h3>AI & Data Engineering</h3>
                <p style="color: var(--text-secondary); margin-top: 0.5rem; margin-bottom: 1rem;">Leverage your data. We build custom AI models, data pipelines, and real-time analytics dashboards that drive intelligent business decisions.</p>
                <span class="learn-more" style="color: #3b82f6; font-size: 0.9rem; font-weight: 600;">Learn More &rarr;</span>
            </a>

            <!-- Box 5: DevOps & Stability Rescue -->
            <a href="/pages/devops-rescue" class="service-card animate-on-scroll" aria-label="Learn about DevOps & Stability Rescue" style="text-decoration: none; display: block; color: inherit;">
                <div class="service-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 2rem; height: 2rem;"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" /></svg>
                </div>
                <h3>Technical Rescue & DevOps</h3>
                <p style="color: var(--text-secondary); margin-top: 0.5rem; margin-bottom: 1rem;">Site down? Deployment failing? We provide 24/7 technical rescue, automation, and stability engineering to keep your systems running at peak performance.</p>
                <span class="learn-more" style="color: #3b82f6; font-size: 0.9rem; font-weight: 600;">Get Started &rarr;</span>
            </a>
        </div>
    </div>
</section>

