<section id="service-details" class="section-padding" style="border-top: 1px solid rgba(255,255,255,0.05);">
    <div class="container">
        <div class="details-grid" style="display: grid; gap: 8rem;">
            <!-- Infrastructure Detail -->
            <div class="detail-block animate-on-scroll" style="display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 6rem; align-items: center;">
                <div class="detail-content">
                    <div class="hero-badge" style="display: inline-block; margin-bottom: 1.5rem; background: rgba(59, 130, 246, 0.1); border: 1px solid rgba(59, 130, 246, 0.2); border-radius: 100px; padding: 0.4rem 1rem; color: #3b82f6; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Infrastructure Excellence</div>
                    <h3 style="font-size: 2.5rem; margin-bottom: 1.5rem;">Mission-Critical Infrastructure</h3>
                    <p style="color: #a1a1aa; font-size: 1.1rem; line-height: 1.7;">Engineering the foundation of your digital ecosystem for absolute reliability and lightning-fast global delivery.</p>
                    <ul style="list-style: none; padding: 0; margin: 2.5rem 0; color: #a1a1aa; line-height: 2.2;">
                        <li style="display: flex; align-items: center; gap: 0.75rem;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Cloud-Native Distributed Architecture</li>
                        <li style="display: flex; align-items: center; gap: 0.75rem;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Zero-Downtime CI/CD Pipelines</li>
                        <li style="display: flex; align-items: center; gap: 0.75rem;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Advanced Security Compliance & Pentesting</li>
                        <li style="display: flex; align-items: center; gap: 0.75rem;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Real-time Observability & Self-Healing</li>
                    </ul>
                    <a href="#contact" class="btn btn-blue" style="padding: 1rem 2.5rem; border-radius: 100px; text-decoration: none; font-weight: 600;">Consult an Infrastructure Lead</a>
                </div>
                <div class="detail-visual" style="background: linear-gradient(145deg, #0f0f0f, #050505); padding: 5rem; border-radius: 40px; border: 1px solid rgba(255,255,255,0.05); box-shadow: 0 30px 60px rgba(0,0,0,0.5); text-align: center;">
                    <div style="font-size: 4rem; font-weight: 800; color: #fff; letter-spacing: -0.05em; margin-bottom: 0.5rem;">99.99<span style="color: #3b82f6;">%</span></div>
                    <div style="color: #3b82f6; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.2em; font-weight: 700;">SLA Guarantee</div>
                </div>
            </div>

            <!-- Deep Dive Audits -->
            <div id="detail-audit" class="detail-block animate-on-scroll">
                <div style="text-align: center; max-width: 800px; margin: 0 auto 5rem;">
                    <div class="hero-badge" style="display: inline-block; margin-bottom: 1.5rem; background: rgba(59, 130, 246, 0.1); border: 1px solid rgba(59, 130, 246, 0.2); border-radius: 100px; padding: 0.4rem 1rem; color: #3b82f6; font-size: 0.8rem; font-weight: 600; text-transform: uppercase;">Performance Engineering</div>
                    <h3 style="font-size: 2.5rem; margin-bottom: 1.5rem;">Technical Audits & Fixes</h3>
                    <p style="color: #a1a1aa; font-size: 1.1rem;">Stop guessing. We identify the exact technical bottlenecks slowing down your growth and fix them permanently.</p>
                </div>

                <div class="audit-pricing-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 3rem;">
                    <!-- Tier 1 -->
                    <div class="pricing-tier" style="border: 1px solid rgba(255,255,255,0.05); padding: 3rem; border-radius: 24px; background: rgba(255,255,255,0.01); display: flex; flex-direction: column; backdrop-filter: blur(10px);">
                        <h4 style="margin-bottom: 0.5rem; color: #fff; font-size: 1.25rem;">Free Mini Audit</h4>
                        <div style="font-size: 2.5rem; font-weight: 800; margin: 1rem 0; color: #3b82f6;">Free<span style="font-size: 1rem; color: var(--text-secondary); font-weight: 400;">/one-time</span></div>
                        <ul style="list-style: none; color: var(--text-secondary); margin-bottom: 3rem; line-height: 2; font-size: 0.95rem; flex-grow: 1;">
                            <li style="display: flex; align-items: center; gap: 0.5rem;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Core Web Vitals Snapshot</li>
                            <li style="display: flex; align-items: center; gap: 0.5rem;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Basic SEO Health Check</li>
                            <li style="display: flex; align-items: center; gap: 0.5rem;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> 3 Critical Action Items</li>
                        </ul>
                        <a href="#contact" class="btn btn-outline" style="width: 100%; border-radius: 100px; padding: 1rem; text-align: center;">Get Free Audit</a>
                    </div>

                    <!-- Tier 2 -->
                    <div class="pricing-tier" style="border: 1px solid #3b82f6; padding: 3.5rem 3rem; border-radius: 24px; background: rgba(59,130,246,0.05); position: relative; display: flex; flex-direction: column; backdrop-filter: blur(10px);">
                        <div style="position: absolute; top: 1.5rem; right: 1.5rem; background: #3b82f6; color: #fff; padding: 4px 12px; border-radius: 20px; font-size: 0.7rem; font-weight: 700;">RECOMMENDED</div>
                        <h4 style="margin-bottom: 0.5rem; color: #fff; font-size: 1.25rem;">Deep Dive Audit</h4>
                        <div style="font-size: 2.5rem; font-weight: 800; margin: 1rem 0; color: #3b82f6;">$997<span style="font-size: 1rem; color: var(--text-secondary); font-weight: 400;">/one-time</span></div>
                        <ul style="list-style: none; color: #fff; margin-bottom: 3rem; line-height: 2; font-size: 0.95rem; flex-grow: 1;">
                            <li style="display: flex; align-items: center; gap: 0.5rem;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Full Codebase Analysis</li>
                            <li style="display: flex; align-items: center; gap: 0.5rem;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Immediate Hands-on Fixes</li>
                            <li style="display: flex; align-items: center; gap: 0.5rem;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Video Handover & Support</li>
                        </ul>
                        <a href="#contact" class="btn btn-blue" style="width: 100%; border-radius: 100px; padding: 1.2rem; text-align: center; font-weight: 700;">Start Deep Dive</a>
                    </div>

                    <!-- Tier 3 -->
                    <div class="pricing-tier" style="border: 1px solid rgba(255,255,255,0.05); padding: 3rem; border-radius: 24px; background: rgba(255,255,255,0.01); display: flex; flex-direction: column; backdrop-filter: blur(10px);">
                        <h4 style="margin-bottom: 0.5rem; color: #fff; font-size: 1.25rem;">Engineering Retainer</h4>
                        <div style="font-size: 2.5rem; font-weight: 800; margin: 1rem 0; color: #3b82f6;">$1,500<span style="font-size: 1rem; color: var(--text-secondary); font-weight: 400;">/month</span></div>
                        <ul style="list-style: none; color: var(--text-secondary); margin-bottom: 3rem; line-height: 2; font-size: 0.95rem; flex-grow: 1;">
                            <li style="display: flex; align-items: center; gap: 0.5rem;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Ongoing Performance Tuning</li>
                            <li style="display: flex; align-items: center; gap: 0.5rem;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Unlimited Small Technical Fixes</li>
                            <li style="display: flex; align-items: center; gap: 0.5rem;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Priority Engineering Channel</li>
                        </ul>
                        <a href="#contact" class="btn btn-outline" style="width: 100%; border-radius: 100px; padding: 1rem; text-align: center;">Join Retainer</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

