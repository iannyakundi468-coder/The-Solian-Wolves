<section class="hero bg-scanning" aria-labelledby="hero-title">
    <div class="hero-content">
        <div class="hero-logo">
            <img src="{{ 'logo.jpg' | asset_url }}" alt="The Solian Wolves Logo"
                width="140" height="140"
                style="width: 100%; height: 100%; object-fit: cover; display: block;" fetchpriority="high">
        </div>





        <div class="hero-badge">

            <span class="pulse-badge" style="background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.2); padding: 0.4rem 1rem; border-radius: 100px; font-size: 0.75rem; color: #3b82f6; font-weight: 600; letter-spacing: 0.05em;">
                ⚡ KENYA'S PREMIER GROWTH AGENCY
            </span>
        </div>
        <h1 style="margin-top: 1rem;">
            Engineering Kenya's <span style="color: #3b82f6;">Best</span> Software Systems.
        </h1>
        <p style="max-width: 600px; margin: 1rem auto 2rem;">We build mission-critical digital infrastructure for visionary founders. Our engineering aims to generate over Ksh 1 Billion in value for Kenyan enterprise.</p>
        
        <div class="hero-actions" style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 2rem;">
            <a href="#contact" class="btn btn-blue pricing-trigger" data-service="free-mini-audit" style="border-radius: 100px; padding: 1.2rem 2.5rem; min-width: 200px;">Get My Free Mini Audit</a>
            <a href="/pages/for-agencies" class="btn btn-outline" style="border-radius: 100px; padding: 1.2rem 2.5rem; min-width: 200px; border-color: rgba(59,130,246,0.3); color: #3b82f6;">Agency Partners</a>
            <a href="#services" class="btn btn-outline" style="border-radius: 100px; padding: 1.2rem 2.5rem; min-width: 200px;">View Solutions</a>
        </div>


        <!-- Trusted By Section - High Contrast Ad Style -->
            <div class="stat-item animate-on-scroll">
                <div style="font-size: 3.5rem; font-weight: 800; color: #fff; line-height: 1;">99.9%</div>
                <div style="color: #3b82f6; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-top: 0.5rem;">System Uptime</div>
            </div>
            <div class="stat-item animate-on-scroll">
                <div style="font-size: 3.5rem; font-weight: 800; color: #fff; line-height: 1;">&lt; 50ms</div>
                <div style="color: #3b82f6; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-top: 0.5rem;">API Response</div>
            </div>
            <div class="stat-item animate-on-scroll">
                <div style="font-size: 3.5rem; font-weight: 800; color: #fff; line-height: 1;">100+</div>
                <div style="color: #3b82f6; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-top: 0.5rem;">KE Systems Deployed</div>
            </div>
            <div class="stat-item animate-on-scroll">
                <div style="font-size: 3.5rem; font-weight: 800; color: #fff; line-height: 1;">24/7</div>
                <div style="color: #3b82f6; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-top: 0.5rem;">Local Engineering Support</div>
            </div>
        </div>
    </div>

    <style>
        .kenya-ticker-wrap {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            overflow: hidden;
            background: rgba(0, 0, 0, 0.8);
            border-top: 1px solid rgba(59, 130, 246, 0.2);
            backdrop-filter: blur(5px);
            padding: 10px 0;
            z-index: 10;
        }

        .kenya-ticker {
            display: flex;
            width: fit-content;
            animation: ticker 30s linear infinite;
        }

        .kenya-ticker-item {
            flex-shrink: 0;
            padding: 0 2rem;
            color: var(--text-secondary);
            font-family: var(--font-heading);
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        @keyframes ticker {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        .pulse-badge {
            animation: pulse-border 2s infinite;
        }

        @keyframes pulse-border {
            0% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(59, 130, 246, 0); }
            100% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0); }
        }
    </style>

    <div class="kenya-ticker-wrap">
        <div class="kenya-ticker">
            <div class="kenya-ticker-item">🇰🇪 Trusted in Nairobi</div>
            <div class="kenya-ticker-item">⚡ M-Pesa Integrated</div>
            <div class="kenya-ticker-item">🚀 99.9% Uptime</div>
            <div class="kenya-ticker-item">💎 Shopify Partners</div>
            <div class="kenya-ticker-item">🇰🇪 Trusted in Nairobi</div>
            <div class="kenya-ticker-item">⚡ M-Pesa Integrated</div>
            <div class="kenya-ticker-item">🚀 99.9% Uptime</div>
            <div class="kenya-ticker-item">💎 Shopify Partners</div>
             <!-- Repeat for seamless loop -->
            <div class="kenya-ticker-item">🇰🇪 Trusted in Nairobi</div>
            <div class="kenya-ticker-item">⚡ M-Pesa Integrated</div>
            <div class="kenya-ticker-item">🚀 99.9% Uptime</div>
            <div class="kenya-ticker-item">💎 Shopify Partners</div>
            <div class="kenya-ticker-item">🇰🇪 Trusted in Nairobi</div>
            <div class="kenya-ticker-item">⚡ M-Pesa Integrated</div>
            <div class="kenya-ticker-item">🚀 99.9% Uptime</div>
            <div class="kenya-ticker-item">💎 Shopify Partners</div>
            <div class="service-header text-center animate-on-scroll">
            <h1 class="service-title" style="background: linear-gradient(to right, #fff, #3b82f6); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Search Engineering Dominance</h1>
            <p class="service-subtitle">We don't just optimize meta tags. We engineer your site to rank #1 on Google's technical stack.</p>
        </div>
    </div>
</section>


